{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "types": ["chrome"],
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src", "manifest.json"]
}
