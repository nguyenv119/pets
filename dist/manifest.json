{
  "manifest_version": 3,
  "name": "Pixel Pets",
  "version": "1.0.0",
  "description": "Pixel pet companions that walk along the bottom of your browser",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "48": "assets/icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "scripting"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/chicken/*.gif",
        "assets/crab/*.gif",
        "assets/dog/*.gif",
        "assets/fox/*.gif",
        "assets/monkey/*.gif",
        "assets/panda/*.gif",
        "assets/snail/*.gif",
        "assets/totoro/*.gif",
        "assets/turtle/*.gif"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}